# ==========================================
# The Python Clean Architecture Boilerplate - Environment Setup
# ==========================================
# Copy this file to .env and replace the placeholder values.
# DO NOT commit the actual .env file to version control.

# --- Environment & Application ---
# APP_ENV: 'local', 'staging', or 'production'
APP_ENV="local"
LOG_LEVEL="DEBUG"

# --- Database Configuration ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://postgres:postgres_secure_pass@localhost:5432/app_db"